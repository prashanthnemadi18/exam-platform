# AI Configuration - Add at least ONE of these
# OpenAI API Key (Recommended - GPT-3.5/GPT-4)
OPENAI_API_KEY=your_openai_api_key_here

# OR Google AI API Key (Alternative)
GOOGLE_GENAI_API_KEY=your_google_ai_api_key_here

# MongoDB - Auto-populated by Vercel when you connect MongoDB
STORAGE_URL=your_mongodb_connection_string_here
# Or
MONGODB_URI=your_mongodb_connection_string_here
