# ========================================
# AI Configuration (Optional)
# ========================================

# Google AI (Recommended - FREE!)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_google_ai_key_here
NEXT_PUBLIC_GOOGLE_GENAI_API_KEY=your_google_ai_key_here

# OpenAI (Alternative - Paid)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# ========================================
# Vercel KV Storage (For Production)
# ========================================
# These are automatically configured when you deploy to Vercel
# For local development, get these from your Vercel project dashboard:
# 1. Go to your project on Vercel
# 2. Click "Storage" tab
# 3. Create a KV database (free tier available)
# 4. Copy the environment variables

# KV_URL=your_kv_url_here
# KV_REST_API_URL=your_kv_rest_api_url_here
# KV_REST_API_TOKEN=your_kv_rest_api_token_here
# KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token_here

# ========================================
# Notes
# ========================================
# - Without KV variables, the app will use in-memory storage (local dev only)
# - In-memory storage is cleared when the server restarts
# - For production on Vercel, you MUST set up Vercel KV storage
